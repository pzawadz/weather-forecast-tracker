# ============================================================================
# POLYMARKET WEATHER BOT - CONFIGURATION
# ============================================================================
# This is your SINGLE SOURCE OF TRUTH for all bot configuration.
# Copy this file to .env and fill in your credentials.
#
# PRIORITY GUIDE:
# [REQUIRED] - Must be set for bot to work
# [RECOMMENDED] - Should be set for best results
# [OPTIONAL] - Can use defaults
# ============================================================================

# ============================================================================
# PLATFORM CREDENTIALS
# ============================================================================

# --- KALSHI (Recommended Primary Platform) ---
# [REQUIRED for Kalshi] Choose ONE authentication method:

# Method 1: Email/Password (easier for getting started)
KALSHI_EMAIL=your_email@example.com
KALSHI_PASSWORD=your_password

# Method 2: API Key (more secure, for production)
# KALSHI_API_KEY_ID=your_api_key_id
# KALSHI_API_PRIVATE_KEY=your_private_key

KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_USE_DEMO=false

# --- POLYMARKET (Optional Secondary Platform) ---
# [OPTIONAL] Only needed if trading on Polymarket
# Leave blank if only using Kalshi

POLYGON_WALLET_PRIVATE_KEY=     # Your Polygon wallet private key (starts with 0x)
CHAINSTACK_RPC_URL=             # Chainstack Polygon RPC endpoint
OPENWEATHER_API_KEY=            # OpenWeatherMap API key (free tier available)

# ============================================================================
# BOT RUNNER CONFIGURATION (Automated Trading)
# ============================================================================
# These control the automated bot daemon (bot-start command)

# --- Capital & Risk Management ---
BANKROLL=1000.0                    # [REQUIRED] Total capital for trading ($)
MAX_DAILY_EXPOSURE_PCT=5.0         # [RECOMMENDED] Max % of bankroll at risk per day (5% = $50 on $1000)

# --- Trading Frequency ---
SCAN_INTERVAL_HOURS=6              # [RECOMMENDED] How often to scan for trades (hours)
RESOLUTION_CHECK_HOURS=1           # [RECOMMENDED] How often to check for resolutions (hours)

# --- Trade Limits ---
MAX_TRADES_PER_SCAN=20             # [RECOMMENDED] Max trades to execute per scan
MAX_TRADES_PER_DAY=50              # [RECOMMENDED] Daily trade limit (safety cap)
MAX_TRADES_PER_CITY=3              # [RECOMMENDED] Max trades per city (diversification)

# ============================================================================
# STRATEGY: EXTREME VALUE BETTING
# ============================================================================
# These control position sizing and entry thresholds

# --- Position Sizing (Target ~$1 average per trade) ---
EXTREME_MIN_POSITION=0.50          # [RECOMMENDED] Minimum bet size ($0.50)
EXTREME_MAX_POSITION=1.00          # [RECOMMENDED] Standard bet size ($1.00)
EXTREME_AGGRESSIVE_MAX=1.50        # [RECOMMENDED] Maximum bet size ($1.50)

# --- Entry Thresholds ---
EXTREME_YES_MAX_PRICE=0.12         # [RECOMMENDED] Buy YES only if price < 12¢
EXTREME_YES_MIN_PRICE=0.03         # [RECOMMENDED] v2.5.0: Skip sub-3¢ traps (0% historical win rate)
EXTREME_YES_IDEAL_PRICE=0.08       # [RECOMMENDED] Ideal YES entry: 8¢
EXTREME_NO_MIN_YES_PRICE=0.50      # [RECOMMENDED] Buy NO only if YES > 50¢
EXTREME_NO_IDEAL_YES_PRICE=0.60    # [RECOMMENDED] Ideal NO entry: YES @ 60¢

# --- Trade Type Preferences (v2.5.0) ---
PREFER_NO_ON_RANGE=true            # [RECOMMENDED] Prioritize NO bets on range markets (18.2% win rate)
SKIP_YES_ON_THRESHOLD=false        # [OPTIONAL] Skip YES bets on threshold markets (4% win rate)
PREFER_NWS_ONLY=true               # [RECOMMENDED] Use NWS data only (Kalshi uses NWS for resolution)

# ============================================================================
# LEGACY SETTINGS (Forecast-Based Strategy - Not Used in v2.1)
# ============================================================================
# These are kept for backward compatibility but NOT used by automated bot

MAX_POSITION_SIZE_USDC=5.0         # [LEGACY] Old position size setting
MIN_EDGE_THRESHOLD=0.05            # [LEGACY] Old edge threshold
MIN_CONFIDENCE=0.70                # [LEGACY] Old confidence threshold
MAX_DAILY_TRADES=50                # [LEGACY] Superseded by MAX_TRADES_PER_DAY
MAX_OPEN_POSITIONS=20              # [LEGACY] Not enforced in v2.1
BANKROLL_USDC=1000.0               # [LEGACY] Superseded by BANKROLL
POSITION_SIZE_PCT=0.01             # [LEGACY] Not used in extreme value strategy
STOP_LOSS_PCT=0.50                 # [LEGACY] Not implemented
POLL_INTERVAL_MINUTES=15           # [LEGACY] Superseded by SCAN_INTERVAL_HOURS

# ============================================================================
# SYSTEM SETTINGS
# ============================================================================

# --- Logging & Debugging ---
LOG_LEVEL=INFO                     # [OPTIONAL] DEBUG, INFO, WARNING, ERROR
SIMULATION_MODE=true               # [RECOMMENDED] Set false for live trading (DANGEROUS!)

# --- Data Storage ---
CACHE_DIR=./data/cache             # [OPTIONAL] Cache directory
WEATHER_DB_DIR=./data/weather_db   # [OPTIONAL] Weather data storage
LOG_DIR=./logs                     # [OPTIONAL] Log file directory

# ============================================================================
# OPTIONAL INTEGRATIONS (Not Currently Used)
# ============================================================================

# --- Telegram Alerts ---
# TELEGRAM_BOT_TOKEN=              # Your Telegram bot token
# TELEGRAM_CHAT_ID=                # Your Telegram chat ID

# --- Additional Weather APIs ---
# WEATHERAPI_KEY=                  # WeatherAPI.com key
# NOAA_API_KEY=                    # NOAA API key

# --- Polymarket CLOB (Advanced) ---
# CLOB_API_KEY=                    # Pre-derived CLOB credentials
# CLOB_SECRET=
# CLOB_PASS_PHRASE=

# ============================================================================
# QUICK START EXAMPLES
# ============================================================================
#
# SIMULATION (2-week validation):
#   KALSHI_EMAIL=you@example.com
#   KALSHI_PASSWORD=yourpassword
#   BANKROLL=1000.0
#   SIMULATION_MODE=true
#   (Keep all other defaults)
#
# LIVE TRADING ($1000 bankroll):
#   KALSHI_EMAIL=you@example.com
#   KALSHI_PASSWORD=yourpassword
#   BANKROLL=1000.0
#   SIMULATION_MODE=false
#   MAX_DAILY_EXPOSURE_PCT=5.0
#   (Keep all other defaults)
#
# CONSERVATIVE (Smaller positions):
#   EXTREME_MIN_POSITION=0.25
#   EXTREME_MAX_POSITION=0.50
#   EXTREME_AGGRESSIVE_MAX=0.75
#   MAX_TRADES_PER_DAY=30
#
# AGGRESSIVE (Larger positions, more trades):
#   EXTREME_MIN_POSITION=1.00
#   EXTREME_MAX_POSITION=2.00
#   EXTREME_AGGRESSIVE_MAX=3.00
#   MAX_TRADES_PER_DAY=100
#   SCAN_INTERVAL_HOURS=4
#
# ============================================================================
