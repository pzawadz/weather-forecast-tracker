# ============================================================================
# POLYMARKET WEATHER BOT - CONFIGURATION
# ============================================================================
# This is your SINGLE SOURCE OF TRUTH for all bot configuration.
# Copy this file to .env and fill in your credentials.
#
# PRIORITY GUIDE:
# [REQUIRED] - Must be set for bot to work
# [RECOMMENDED] - Should be set for best results
# [OPTIONAL] - Can use defaults
# ============================================================================

# ============================================================================
# POLYMARKET AUTHENTICATION
# ============================================================================

# [REQUIRED] Polygon wallet private key (hex string with 0x prefix)
POLYMARKET_PRIVATE_KEY=0x...

# [OPTIONAL] Funder address (defaults to address derived from private key)
POLYMARKET_FUNDER_ADDRESS=

# [OPTIONAL] Proxy wallet address (if using proxy)
POLYMARKET_PROXY_ADDRESS=

# ============================================================================
# WEATHER DATA SOURCE
# ============================================================================

# [RECOMMENDED] Path to weather-forecast-tracker SQLite database
# If set, bot will read bias-corrected forecasts from tracker
# If not set, bot will use Open-Meteo API directly (also good!)
TRACKER_DB_PATH=../weather-forecast-tracker/weather_forecasts.db

# [OPTIONAL] WeatherAPI.com API key (fallback source)
# Only used if Open-Meteo is down. Get free key at: https://www.weatherapi.com/
WEATHERAPI_KEY=

# [REQUIRED] Default temperature unit for markets
# "F" for US markets (Polymarket default), "C" for European markets
DEFAULT_TEMP_UNIT=F

# ============================================================================
# RISK CONTROLS
# ============================================================================

# [CRITICAL] Simulation mode - MUST be true until calibration complete!
# When true: bot analyzes markets but doesn't place real orders
SIMULATION_MODE=true

# [REQUIRED] Circuit breakers - bot pauses if losses exceed these limits
CIRCUIT_BREAKER_DAILY_LOSS=-50.00

# [REQUIRED] Position limits
MAX_POSITION_PER_MARKET=10.00
MAX_TRADES_PER_DAY=25
MAX_TRADES_PER_SCAN=20
MAX_SINGLE_TRADE_USD=5.00

# [REQUIRED] Daily exposure limit (% of bankroll)
MAX_DAILY_EXPOSURE_PCT=0.05

# ============================================================================
# MARKET FILTERS
# ============================================================================

# [RECOMMENDED] Minimum market liquidity (USD) - skip thin markets
MIN_MARKET_LIQUIDITY_USD=500

# [REQUIRED] Minimum price (cents) - skip sub-3-cent markets (traps)
MIN_PRICE_CENTS=3

# [REQUIRED] Maximum forecast horizon (days) - don't bet on weather >5 days out
MAX_FORECAST_DAYS=5

# [REQUIRED] Minimum model count - skip if <3 weather models have data
MIN_MODEL_COUNT=3

# ============================================================================
# STRATEGY PARAMETERS
# ============================================================================

# [REQUIRED] Base sigma values (forecast uncertainty)
# These will be calibrated weekly based on actual performance
# Europe: 3.5°F / 2.0°C (ECMWF, ICON more accurate)
# US: 5.0°F / 2.8°C (GFS less accurate for short-term)
BASE_SIGMA_F=4.0
BASE_SIGMA_C=2.2

# [REQUIRED] Minimum edge to trade (Kelly criterion)
# 0.05 = 5% edge required before placing bet
MIN_EDGE=0.05

# ============================================================================
# MONITORING & ALERTS
# ============================================================================

# [OPTIONAL] Telegram notifications
# Get bot token from @BotFather, get chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================================
# LOGGING
# ============================================================================

# [OPTIONAL] Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# [OPTIONAL] Log file path
LOG_FILE=logs/bot.log

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# [OPTIONAL] Custom config file paths
LOCATIONS_CONFIG_PATH=config/locations.json
CALIBRATION_CONFIG_PATH=config/calibration.json

# [OPTIONAL] Database path for trade history
DB_PATH=data/bot.db

# [OPTIONAL] Cache TTL (seconds) for weather forecasts
WEATHER_CACHE_TTL=900
